# =============================================
# Recruitment Platform Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# Database
DATABASE_URL=postgres://postgres:password@db:5432/recruitment_db

# Security
JWT_SECRET=your-super-secret-jwt-key-change-this
WEBHOOK_SECRET=your-webhook-secret

# Telegram Bot
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_BOT_WEBHOOK_URL=https://your-domain.com/api/webhook/telegram

# Frontend/WebApp URL (used for registration links, CV downloads)
WEBAPP_URL=https://your-domain.com

# OpenAI (for AI features)
OPENAI_API_KEY=your-openai-api-key
MAX_AI_QUESTIONS=25

# Rate Limiting
PUBLIC_RPS=20
INTEGRATION_RPS=10

# 1F Integration (comma-separated list of OneF base URLs — leave empty to disable)
# Every notification is sent to ALL listed servers concurrently.
ONEF_BASE_URLS=http://192.168.1.47/app/v1.2/api/publications,http://192.168.1.38/app/v1.2/api/publications
# Legacy fallback (used if ONEF_BASE_URLS is not set):
# ONEF_WEBHOOK_URL=

# Frontend API URL (for client-side calls, leave empty if using proxy)
NEXT_PUBLIC_API_URL=
